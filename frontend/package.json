{
  "name": "frontend",
  "version": "1.0.0",
  "description": "Sistema de gestion, inventario, facturacion y compras",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build --base ./",
    "preview": "vite preview --host 0.0.0.0",
    "electron": "electron .",
    "preview:desktop": "npm run build && electron .",
    "build:desktop": "npm run build && electron-builder",
    "build:pages": "vite build --base /"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.16.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  },
  "productName": "INVE-FAT SYSTEM",
  "build": {
    "appId": "com.invefat.system",
    "productName": "INVE-FAT SYSTEM",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "INVE-FAT SYSTEM"
    }
  }
}
